# JARVIS Local - Variables de entorno (ejemplo)
# Copia este archivo como .env y ajusta los valores.
# En Fase 1 no se requieren claves API reales.

# Ollama (local, sin API key)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# No se requieren claves de API en esta fase.
# Las siguientes son para fases futuras (NO USAR AHORA):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
